<mvc:View controllerName="sacde.PortalProveedores.controller.Register" xmlns="sap.m" xmlns:mvc="sap.ui.core.mvc"
	xmlns:core="sap.ui.core" displayBlock="true">

			<Page class="registrationBackground" showNavButton="true" navButtonPress="onNavBack" enableScrolling="true">
				<FlexBox class="registrationBackground fullHeight" justifyContent="Center" alignItems="Center" direction="Column"
					height="100%">
					<MessageStrip id="msgStrip" visible="false" showCloseButton="true" class="sapUiSmallMarginBottom" dismissible="true" text=""
						type="Information"/>
					<VBox width="420px" class="sapUiMediumMargin sectionPanel">
						<HBox justifyContent="Center" class="sapUiSmallMarginBottom sapUiMediumMarginTop">
							<Image src="img/logosacde.png" width="115px"/>
						</HBox>
						<Title text="Registro de Administrador" level="H2" textAlign="Center" class="sapUiTinyMarginBottom sapUiSmallMarginBottom"/>
						<Text text="Por favor completa todos los campos" textAlign="Center" class="sapUiSmallMarginBottom" width="100%"/>
						<Input id="inputNombre" placeholder="Nombre Completo" required="true" value="{usuario>/usuario}" class="sapUiSmallMarginBottom"/>
						<ComboBox id="countryComboBox" items="{ path: 'countryModel>/countries' }" placeholder="País" selectedKey="{usuario>/pais}"
							showSecondaryValues="true" class="sapUiSmallMarginBottom">
							<core:ListItem key="{countryModel>Key}" text="{countryModel>Texto}" additionalText="{countryModel>Key}"/>
						</ComboBox>
						<Input id="inputEmail" placeholder="Email" type="Email" required="true" liveChange="onLiveEmailChange" value="{usuario>/email}" class="sapUiSmallMarginBottom"/>
						<Input id="inputValidarEmail" placeholder="Validar Email" type="Email" required="true" liveChange="onLiveConfirmEmailChange" class="sapUiSmallMarginBottom"/>
						<Input id="inputContrasena" placeholder="Contraseña" type="Password" required="true" liveChange="onLivePasswordChange"
							value="{usuario>/contrasena}" class="sapUiSmallMarginBottom"/>
						<Input id="inputConfirmarContrasena" placeholder="Confirmar Contraseña" type="Password" required="true"
							liveChange="onLiveConfirmPasswordChange" class="sapUiSmallMarginBottom"/>
						<Input id="inputCUIT" placeholder="NIF/CUIT" value="{usuario>/cuit}" liveChange=".onLiveChangeCuit" required="true" class="sapUiSmallMarginBottom"/>
						<Input id="inputRazonSocial" placeholder="Razón Social" required="true" value="{usuario>/razon_soc}" liveChange="_updateFormState" class="sapUiSmallMarginBottom"/>
						<Button text="Registrar" press="onCreate" type="Emphasized" enabled="{viewModel>/formValid}" class="sapUiMediumMarginTop sapUiSmallMarginBottom"/>
					</VBox>
				</FlexBox>
			</Page>
</mvc:View>
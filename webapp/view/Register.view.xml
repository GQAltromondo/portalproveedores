<mvc:View controllerName="sacde.PortalProveedores.controller.Register" xmlns="sap.m" xmlns:mvc="sap.ui.core.mvc"
	xmlns:core="sap.ui.core" displayBlock="true">

			<Page class="registrationBackground"  showNavButton="true" navButtonPress="onNavBack">
				<FlexBox class="registrationBackground fullHeight sapUiSmallMargin" justifyContent="Center" alignItems="Center" direction="Column"
					height="100%">
					<MessageStrip id="msgStrip" visible="false" showCloseButton="true" class="sapUiSmallMarginBottom" dismissible="true" text=""
						type="Information"/>
					<VBox width="400px" class="sapUiMediumMargin">
						<Image src="img/logosacde.png" width="115px"/>
						<Title text="Registro de Administrador" level="H2" textAlign="Center" class="sapUiTinyMarginBottom text-white"/>
						<Input id="inputNombre" placeholder="Nombre Completo" required="true" value="{usuario>/usuario}"/>
						<ComboBox id="countryComboBox" items="{ path: 'countryModel>/countries' }" placeholder="Pais" selectedKey="{usuario>/pais}"
							showSecondaryValues="true">
							<core:ListItem key="{countryModel>Key}" text="{countryModel>Texto}" additionalText="{countryModel>Key}"/>
						</ComboBox>
						<Input id="inputEmail" placeholder="Email" type="Email" required="true" liveChange="onLiveEmailChange" value="{usuario>/email}"/>
						<Input id="inputValidarEmail" placeholder="Validar Email" type="Email" required="true" liveChange="onLiveConfirmEmailChange"/>
						<Input id="inputContrasena" placeholder="Contraseña" type="Password" required="true" liveChange="onLivePasswordChange"
							value="{usuario>/contrasena}"/>
						<Input id="inputConfirmarContrasena" placeholder="Confirmar Contraseña" type="Password" required="true"
							liveChange="onLiveConfirmPasswordChange"/>
						<Input id="inputCUIT" placeholder="NIF/CUIT" value="{usuario>/cuit}" liveChange=".onLiveChangeCuit" required="true"/>
						<Input id="inputRazonSocial" placeholder="Razón Social" required="true" value="{usuario>/razon_soc}" liveChange="_updateFormState"/>
						<!--<Button text="Registrar" press="onRegistrarAdmin" type="Emphasized"/>-->
						<Button text="Registrar" press="onCreate" type="Emphasized"  enabled="{viewModel>/formValid}"/>
					</VBox>
				</FlexBox>
			</Page>
</mvc:View>